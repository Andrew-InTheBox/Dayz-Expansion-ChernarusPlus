<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<weather reset="1" enable="1">
    <overcast>
        <!-- Set initial conditions to clear -->
        <current actual="0.2" time="120" duration="120" />
        <limits min="0.0" max="1.0" />
        <!-- Increased minimum time between changes to reduce frequency -->
        <timelimits min="1200" max="1800" />
        <changelimits min="0.0" max="0.7" />
    </overcast>
    <fog>
        <current actual="0.0" time="120" duration="120" />
        <limits min="0.0" max="1.0" />
        <timelimits min="900" max="1800" />
        <changelimits min="0.0" max="0.5" />
    </fog>
    <rain>
        <current actual="0.0" time="120" duration="120" />
        <limits min="0.0" max="1.0" />
        <timelimits min="600" max="900" />
        <changelimits min="0.0" max="0.6" />
        <!-- Key change: Make rain require higher overcast to trigger -->
        <thresholds min="0.7" max="1.0" end="300" />
    </rain>
    <wind>
        <maxspeed>20</maxspeed>
        <params min="0.0" max="1.0" frequency="30" />
    </wind>
    <storm density="1.0" threshold="0.7" timeout="25"/>
</weather>